{
  "name": "ai-hub",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:vm": "pnpm --filter vm-server dev",
    "dev:app": "pnpm --filter electron-app dev",
    "dev": "pnpm run dev:vm & pnpm run dev:app",
    "build:vm": "pnpm --filter vm-server build",
    "build:app": "pnpm --filter electron-app build",
    "test": "pnpm --filter vm-server test && pnpm --filter electron-app test"
  },
  "devDependencies": {
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.30.1+sha512.3590e550d5384caa39bd5c7c739f72270234b2f6059e13018f975c313b1eb9fefcc09714048765d4d9efe961382c312e624572c0420762bdc5d5940cdf9be73a",
  "pnpm": {
    "onlyBuiltDependencies": ["electron", "esbuild", "sharp", "better-sqlite3"]
  }
}
