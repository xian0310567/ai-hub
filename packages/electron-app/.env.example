# ── VM 서버 연결 ───────────────────────────────────────────────────
# 중앙 서버 IP/도메인으로 변경 (로컬 개발 시 localhost 그대로 사용)
VM_SERVER_URL=http://localhost:4000

# ── 로컬 앱 포트 ───────────────────────────────────────────────────
PORT=3000

# ── 데이터 저장 경로 (선택, 기본값: ./.data) ───────────────────────
# DATA_DIR=/custom/path/.data
