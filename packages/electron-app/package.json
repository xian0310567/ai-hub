{
  "name": "electron-app",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"next dev\" \"wait-on http://localhost:3000 && electron .\"",
    "dev:next": "next dev",
    "build": "next build && electron-builder build",
    "start": "NODE_ENV=production next start",
    "electron:dev": "electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "vault:add": "node scripts/vault-add.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.1.2",
    "electron": "^35.1.5",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^2.1.0",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.aihub.app",
    "productName": "AI Hub",
    "files": [
      "electron/**/*",
      ".next/**/*",
      "public/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
