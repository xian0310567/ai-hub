{
  "name": "standalone-openclaw",
  "version": "0.1.0",
  "description": "Standalone OpenClaw + Claude CLI package — run agents without electron-app or vm-server",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "standalone-openclaw": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "setup": "node dist/cli.js setup"
  },
  "files": [
    "dist/"
  ],
  "dependencies": {
    "openclaw": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT"
}
