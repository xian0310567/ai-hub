# ── Dev 환경 (.env.dev) ───────────────────────────────────────────────
# docker-compose.dev.yml 에서 env_file로 로드됨
# DATABASE_URL은 docker-compose에서 주입하므로 여기 불필요

PORT=4000
HOST=0.0.0.0
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# 세션 쿠키 서명 키 (dev용 고정값 OK)
COOKIE_SECRET=dev-cookie-secret-at-least-32-characters!!

# Vault 마스터 키 — 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VAULT_MASTER_KEY=

# Anthropic API 키 (fallback daemon용, 선택)
ANTHROPIC_API_KEY=

# Webhook HMAC 서명 키 (선택)
WEBHOOK_SECRET=
