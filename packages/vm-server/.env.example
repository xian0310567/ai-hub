# ── 서버 설정 ──────────────────────────────────────────────────────
PORT=4000
HOST=0.0.0.0

# 허용할 클라이언트 origins (쉼표 구분)
ALLOWED_ORIGINS=http://localhost:3000

# ── DB 연결 (PostgreSQL) ───────────────────────────────────────────
# 로컬: docker run -e POSTGRES_USER=aihub -e POSTGRES_PASSWORD=aihub1234 -e POSTGRES_DB=aihub -p 5432:5432 postgres:16-alpine
DATABASE_URL=postgres://aihub:aihub1234@localhost:5432/aihub

# ── 보안 키 (변경 필수) ────────────────────────────────────────────
# 세션 쿠키 서명 키
COOKIE_SECRET=change-me-in-production-use-random-32chars

# Vault 마스터 키 (KEK) — 32바이트 hex, DB에 저장 금지
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VAULT_MASTER_KEY=

# Webhook HMAC 서명 키 (선택)
WEBHOOK_SECRET=

# ── Anthropic (Fallback 데몬용, 선택) ─────────────────────────────
ANTHROPIC_API_KEY=

# ── 데이터 저장 경로 ───────────────────────────────────────────────
DATA_DIR=./.data

# ── 워커 튜닝 (선택) ──────────────────────────────────────────────
# FALLBACK_POLL_MS=5000
# SCHEDULER_POLL_MS=60000
# PG_BACKUP_INTERVAL_MS=21600000
