# 서버 설정
PORT=4000
HOST=0.0.0.0

# 허용할 클라이언트 origins (쉼표 구분)
ALLOWED_ORIGINS=http://localhost:3000

# 세션 쿠키 서명 키 (변경 필수)
COOKIE_SECRET=change-me-in-production-use-random-32chars

# Vault 마스터 키 (KEK) - 32바이트 hex (변경 필수, DB에 저장 금지)
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VAULT_MASTER_KEY=

# 데이터 저장 경로
DATA_DIR=./.data
