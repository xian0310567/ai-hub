# ── Prod 환경 (.env.prod) ─────────────────────────────────────────────
# docker-compose.prod.yml 에서 env_file로 로드됨
# DATABASE_URL은 docker-compose에서 주입하므로 여기 불필요

PORT=4000
HOST=0.0.0.0
ALLOWED_ORIGINS=https://your-domain.com

# ⚠️ 반드시 변경 — 최소 32자 랜덤 문자열
COOKIE_SECRET=

# ⚠️ 반드시 변경 — 32바이트 hex
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VAULT_MASTER_KEY=

# PostgreSQL (docker-compose.prod.yml 용)
POSTGRES_USER=aihub
POSTGRES_PASSWORD=

# Anthropic API 키 (fallback daemon용)
ANTHROPIC_API_KEY=

# Webhook HMAC 서명 키 (선택)
WEBHOOK_SECRET=
